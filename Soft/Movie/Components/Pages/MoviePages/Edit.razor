@page "/movies/edit"
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyEditPage PageTitleText="Edit"
            EntityTitle="@movie?.Name"
            BasePath="/movies"
            OnValidSubmit="updateMovie"
            Entity="movie"
			EntityId="@Id" />

@code {
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    [SupplyParameterFromForm] private Movie movie { get; set; }
    protected override async Task OnInitializedAsync()
    {
        movie ??= await repo.GetAsync(Id);
        if (movie is null) NavigationManager.NotFound();
    }
    private async Task updateMovie()
    {
        await repo.UpdateAsync(movie!);
        NavigationManager.NavigateTo("/movies");
    }
}
