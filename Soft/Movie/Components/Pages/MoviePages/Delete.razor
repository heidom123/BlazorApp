@page "/movies/delete"
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete a Movie"
              EntityTitle="Movie"
              Entity="movie"
              BasePath="/movies"
			  OnValidSubmit="DeleteMovie" />

@code {
    private Movie movie;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        movie = await repo.GetAsync(Id);
        if (movie is null) NavigationManager.NotFound();
    }

    private async Task DeleteMovie()
    {
        await repo.DeleteAsync(Id);
        NavigationManager.NavigateTo("/movies");
    }


}
