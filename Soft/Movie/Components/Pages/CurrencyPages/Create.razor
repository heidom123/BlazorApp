@page "/currencies/create"
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage PageTitleText="Create a Currency"
              EntityTitle="Currency"
              Entity="currency"
              BasePath="/currencies"
              OnValidSubmit="AddCurrency" />

@code {
    [SupplyParameterFromForm] private Currency currency { get; set; } = default!;
    protected override void OnInitialized() => currency ??= new();
    private async Task AddCurrency() {
        await repo.CreateAsync(currency);
        NavigationManager.NavigateTo("/currencies");
    }
}
