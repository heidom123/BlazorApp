@page "/countries/create"
@using Abc.Data
@using Abc.Infra
@using Abc.Shared.Components
@using Microsoft.EntityFrameworkCore
@inject ICountriesRepo repo
@inject NavigationManager NavigationManager

<PageTitle>CreateCountry</PageTitle>

<h1>Create Country</h1>

<h2>Country</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="country" OnValidSubmit="addCountry" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <MyPropertyEditor TValue="string" Id="name" Label="Name:" @bind-Value="country.Name" />
            <MyPropertyEditor TValue="string" Id="code" Label="Code:" @bind-Value="country.Code" />
            <MyPropertyEditor TValue="string" Id="details" Label="Details:" @bind-Value="country.Details" />
            <MyPropertyEditor TValue="string" Id="isoCode" Label="IsoCode:" @bind-Value="country.IsoCode" />
            <MyPropertyEditor TValue="string" Id="nativeName" Label="NativeName:" @bind-Value="country.NativeName" />
            <MyPropertyEditor TValue="string" Id="numbericCode" Label="NumericCode:" @bind-Value="country.NumericCode" />
            <MyPropertyEditor TValue="string" Id="officialName" Label="OfficialName:" @bind-Value="country.OfficialName" />
            <MyPropertyEditor TValue="DateTime" Id="ValidFrom" Label="Valid from:" @bind-Value="country.ValidFrom" />
            <MyPropertyEditor TValue="DateTime" Id="ValidTo" Label="Valid to:" @bind-Value="country.ValidTo" />
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div> 

<div>
    <a href="/countries">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm] private Country country { get; set; } = default!;

    protected override void OnInitialized() => country ??= new();

    // To protect from overposting attacks, see https://learn.microsoft.com/aspnet/core/blazor/forms/#mitigate-overposting-attacks.
    private async Task addCountry()
    {
		await repo.CreateAsync(country);
        NavigationManager.NavigateTo("/countries");
    }
}
