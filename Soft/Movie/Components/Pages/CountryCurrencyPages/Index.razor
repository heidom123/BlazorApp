@page "/countrycurrencies"
@rendermode InteractiveServer
@inject ICountryCurrenciesRepo repo

<MyIndexPage TItem="CountryCurrency"
             PageTitleText="CountryCurrencies"
             EntityTitle="CountryCurrency"
             Items="countrycurrencies"
             BasePath="/countrycurrencies" />

@code {
    private IQueryable<CountryCurrency> countrycurrencies = Enumerable.Empty<CountryCurrency>().AsQueryable();
    protected override async Task OnInitializedAsync() {
        if (repo is null) return;
        countrycurrencies = (await repo.GetAsync()).AsQueryable();
    }
}

