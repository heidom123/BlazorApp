@page "/countrycurrencies/create"
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage PageTitleText="Create a CountryCurrency"
              EntityTitle="CountryCurrency"
              Entity="countryCurrency"
              BasePath="/countrycurrencies"
              OnValidSubmit="AddCountryCurrency" />

@code {
    [SupplyParameterFromForm] private CountryCurrency countryCurrency { get; set; } = default!;
    protected override void OnInitialized() => countryCurrency ??= new();
    private async Task AddCountryCurrency() {
        await repo.CreateAsync(countryCurrency);
        NavigationManager.NavigateTo("/countrycurrencies");
    }
}
