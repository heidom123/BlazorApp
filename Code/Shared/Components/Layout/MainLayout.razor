@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@MudBlazor.Icons.Material.Filled.Menu"
                       Color="Color.Inherit" Edge="Edge.Start" OnClick="toggleDrawer" />
        <MudText Typo="Typo.h6">@Title</MudText>
        <MudSpacer />
    </MudAppBar>
    <MudDrawer @bind-Open="isDrawerOpen" ClipMode="DrawerClipMode.Always"
               Elevation="1" Variant="DrawerVariant.Responsive">
        @NavMenu
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="main-content py-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment NavMenu { get; set; }
    private bool isDrawerOpen = true;
    private void toggleDrawer() {
        isDrawerOpen = !isDrawerOpen;
    }
}
