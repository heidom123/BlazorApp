@page "/movies/details"
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager

<MyDetailsPage PageTitleText="Movie Details"
               EntityTitle="@movie?.Name"
               BasePath="/movies"
               Entity="movie"
			   EntityId="Id" />

@code {
    private Movie movie;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        movie = await repo.GetAsync(Id);
        if (movie is null) NavigationManager.NotFound();
    }
}
