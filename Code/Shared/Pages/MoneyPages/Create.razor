@page "/moneys/create"
@inject IMoneysRepo repo
@inject NavigationManager NavigationManager

<MyCreatePage PageTitleText="Create a Money"
              EntityTitle="Money"
              Entity="money"
              BasePath="/moneys"
              OnValidSubmit="AddMoney" />

@code {
    [SupplyParameterFromForm] private Money money { get; set; } = default!;
    protected override void OnInitialized() => money ??= new();
    private async Task AddMoney() {
        await repo.CreateAsync(money);
        NavigationManager.NavigateTo("/moneys");
    }
}
