@page "/moneys/delete"
@inject IMoneysRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete a Money"
              EntityTitle="Money"
              Entity="money"
              BasePath="/moneys"
              OnValidSubmit="DeleteMoney" />

@code {
    private Money money;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        money = await repo.GetAsync(Id);
        if (money is null) NavigationManager.NotFound();
    }

    private async Task DeleteMoney() {
        await repo.DeleteAsync(Id);
        NavigationManager.NavigateTo("/moneys");
    }
}
