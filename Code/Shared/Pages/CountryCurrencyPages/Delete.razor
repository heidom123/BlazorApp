@page "/countrycurrencies/delete"
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager

<MyDeletePage PageTitleText="Delete a CountryCurrency"
              EntityTitle="CountryCurrency"
              Entity="countryCurrency"
              BasePath="/countrycurrencies"
              OnValidSubmit="DeleteCountryCurrency" />

@code {
    private CountryCurrency countryCurrency;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        countryCurrency = await repo.GetAsync(Id);
        if (countryCurrency is null) NavigationManager.NotFound();
    }

    private async Task DeleteCountryCurrency() {
        await repo.DeleteAsync(Id);
        NavigationManager.NavigateTo("/countrycurrencies");
    }
}
