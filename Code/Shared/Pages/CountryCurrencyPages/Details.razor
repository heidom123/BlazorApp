@page "/countrycurrencies/details"
@inject NavigationManager NavigationManager
@inject ICountryCurrenciesRepo repo

<MyDetailsPage PageTitleText="CountryCurrency Details"
               EntityTitle="CountryCurrency"
               BasePath="/countrycurrencies"
               Entity="countryCurrency"
               EntityId="Id" />

@code {
    private CountryCurrency countryCurrency;
    [SupplyParameterFromQuery] private Guid Id { get; set; }
    protected override async Task OnInitializedAsync() {
        countryCurrency = await repo.GetAsync(Id);
        if (countryCurrency is null) NavigationManager.NotFound();
    }
}
